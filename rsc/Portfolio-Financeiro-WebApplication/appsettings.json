{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Application": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "InMemory": {
      "ProductionName": "portfolio-analytics-production",
      "IntegrationTestName": "portfolio-analytics-integration-tests"
    }
  },
  "RateLimiting": {
    "Analytics": {
      "PermitLimit": 60,
      "WindowSeconds": 60
    }
  },
  "AllowedHosts": "*"
}
